{
    "manifest_version" : 3,
    "name" : "Caption Interceptor",
    "version" : "1.0",
    "description" : "Intercepts YouTube captions and sends to backend",
    "permissions" : ["activeTab", "storage"],
    "host_permissions" : [
        "https://*.youtube.com/*",
        "http://localhost:8000/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Simply Assistant"
    },
    "background" : {
        "service_worker" : "background.js"
    },
    "content_scripts" : [
        {
            "matches" : ["*://*.youtube.com/watch*"],
            "js" : ["inject.js"],
            "world" : "MAIN",
            "run_at" : "document_start"
        },
        {
            "matches" : ["*://*.youtube.com/watch*"],
            "js" : ["content.js"],
            "run_at" :"document_start"
        }
    ]
}