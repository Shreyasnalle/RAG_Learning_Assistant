{
    "manifest_version" : 3,
    "name" : "Caption Interceptor",
    "version" : "1.0",
    "description" : "Intercepts YouTube captions and sends to backend",
    "permissions" : [
        "activeTab"
    ],
    "host_permissions" : [
        "https://*.youtube.com/*"
    ],
    "content_scripts" : [
        {
            "matches" : ["https://*.youtube.com/*"],
            "js" : ["inject.js"],
            "world" : "MAIN",
            "run_at" : "document_start"
        }
    ]
}